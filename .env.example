# Environment
NODE_ENV=development

# API Gateway
API_GATEWAY_PORT=3000
API_GATEWAY_HOST=localhost

# Auth Service
AUTH_SERVICE_PORT=3001
AUTH_SERVICE_HOST=localhost
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=7d

# Catalog Service
CATALOG_SERVICE_PORT=3002
CATALOG_SERVICE_HOST=localhost

# Cart Service
CART_SERVICE_PORT=3003
CART_SERVICE_HOST=localhost

# Order Service
ORDER_SERVICE_PORT=3004
ORDER_SERVICE_HOST=localhost

# Payment Service
PAYMENT_SERVICE_PORT=3005
PAYMENT_SERVICE_HOST=localhost

# Inventory Service
INVENTORY_SERVICE_PORT=3006
INVENTORY_SERVICE_HOST=localhost

# Notification Service
NOTIFICATION_SERVICE_PORT=3007
NOTIFICATION_SERVICE_HOST=localhost

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=ecommerce_user
DB_PASSWORD=ecommerce_password
DB_NAME=ecommerce_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Stripe Payment
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# JWT
JWT_ALGORITHM=HS256
