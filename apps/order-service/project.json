{
  "name": "order-service",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/order-service/src",
  "prefix": "order",
  "tags": ["type:service", "framework:nestjs"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/apps/order-service/dist"],
      "options": {
        "command": "tsc -p tsconfig.app.json",
        "cwd": "apps/order-service"
      }
    },
    "start:dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nest start --watch",
        "cwd": "apps/order-service"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/order-service/jest.config.ts",
        "passWithNoTests": true
      }
    }
  }
}
